{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "npm install --legacy-peer-deps",
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, s-maxage=60, stale-while-revalidate=300" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ],
  "crons": [
    { "path": "/api/cron/fetch-feeds", "schedule": "*/10 * * * *" },
    { "path": "/api/cron/validate-feeds", "schedule": "0 */6 * * *" },
    { "path": "/api/cron/generate-reports", "schedule": "0 6 * * *" },
    { "path": "/api/cron/send-briefing", "schedule": "0 8 * * *" },
    { "path": "/api/admin/source-health", "schedule": "0 */6 * * *" }
  ]
}
