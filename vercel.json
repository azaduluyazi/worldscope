{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "npm install --legacy-peer-deps",
  "redirects": [
    {
      "source": "/:path(.*)",
      "has": [{ "type": "host", "value": "www.troiamedia.com" }],
      "destination": "https://troiamedia.com/:path",
      "permanent": true
    },
    {
      "source": "/:path(.*)",
      "has": [{ "type": "host", "value": "worldscope-azaduluyazi-4783s-projects.vercel.app" }],
      "destination": "https://troiamedia.com/:path",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, s-maxage=60, stale-while-revalidate=300" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ],
  "crons": [
    { "path": "/api/cron/fetch-feeds", "schedule": "*/20 * * * *" },
    { "path": "/api/cron/fetch-bluesky", "schedule": "*/30 * * * *" },
    { "path": "/api/cron/validate-feeds", "schedule": "0 */12 * * *" },
    { "path": "/api/cron/generate-reports", "schedule": "0 6 * * *" },
    { "path": "/api/cron/send-briefing", "schedule": "0 8 * * *" },
    { "path": "/api/admin/source-health", "schedule": "0 */12 * * *" },
    { "path": "/api/cron/convergence", "schedule": "*/10 * * * *" },
    { "path": "/api/cron/calibrate-convergence", "schedule": "0 4 * * 1" },
    { "path": "/api/cron/seed-market", "schedule": "*/5 * * * *" },
    { "path": "/api/cron/seed-aviation", "schedule": "*/10 * * * *" },
    { "path": "/api/cron/seed-natural", "schedule": "*/10 * * * *" },
    { "path": "/api/cron/seed-cyber", "schedule": "*/20 * * * *" },
    { "path": "/api/cron/seed-conflict", "schedule": "*/30 * * * *" },
    { "path": "/api/cron/seed-economic", "schedule": "0 */2 * * *" },
    { "path": "/api/cron/seed-radiation", "schedule": "*/30 * * * *" },
    { "path": "/api/cron/cache-warm", "schedule": "*/30 * * * *" },
    { "path": "/api/cron/generate-blog", "schedule": "0 7 * * 1" },
    { "path": "/api/cron/validate-all-feeds", "schedule": "30 */12 * * *" },
    { "path": "/api/cron/unified-report", "schedule": "0 8 * * *" },
    { "path": "/api/cron/seed-to-events", "schedule": "*/20 * * * *" },
    { "path": "/api/cron/telegram-signals", "schedule": "0,30 * * * *" },
    { "path": "/api/cron/bluesky-ingest", "schedule": "*/20 * * * *" },
    { "path": "/api/cron/run-alerts", "schedule": "5,25,45 * * * *" },
    { "path": "/api/cron/generate-country-briefings", "schedule": "0 6 * * *" },
    { "path": "/api/cron/send-daily-briefings", "schedule": "0 7 * * *" },
    { "path": "/api/cron/send-weekly-briefings", "schedule": "0 8 * * 1" }
  ]
}
