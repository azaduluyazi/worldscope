# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Upstash Redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Map
NEXT_PUBLIC_MAPBOX_TOKEN=

# News Aggregators
NEWSAPI_KEY=
GNEWS_API_KEY=

# Market Data
ALPHA_VANTAGE_KEY=

# AI — LLM (Groq for narratives)
GROQ_API_KEY=

# AI — Embeddings (Gemini for convergence semantic similarity)
# Free tier: 1500 RPM. Get one at https://aistudio.google.com/app/apikey
# Convergence engine degrades gracefully if missing — semantic dedup
# and cross-region linking will be skipped, geo+time clustering still
# works. Required for full v3 functionality.
GEMINI_API_KEY=

# Lemon Squeezy — payments (Merchant of Record)
# Dashboard: https://app.lemonsqueezy.com
# - API Key: Settings → API → Create API Key (JWT, full write scope)
# - Webhook Secret: Settings → Webhooks → your webhook → Signing secret
#   MUST be generated with `openssl rand -hex 32` — NOT a short dictionary word
# - Store ID: Settings → Stores → numeric ID shown next to store name
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_STORE_ID=

# Lemon Squeezy variant IDs per pantheon tier.
# Each is the variant (NOT product) id of the monthly-recurring variant
# created in the Lemon dashboard. When unset, the /pricing page shows
# "Coming Soon" for that tier instead of a Subscribe button — so you can
# roll out one tier at a time safely. These are NEXT_PUBLIC_* because
# variant ids are not secret (they end up in the checkout URL anyway).
# Chora ($1) retired 2026-04-21 — uneconomic under Lemon's $0.50 fee.
NEXT_PUBLIC_LEMONSQUEEZY_VARIANT_PLEIADES=
NEXT_PUBLIC_LEMONSQUEEZY_VARIANT_GAIA=
NEXT_PUBLIC_LEMONSQUEEZY_VARIANT_PROMETHEUS=
NEXT_PUBLIC_LEMONSQUEEZY_VARIANT_PANTHEON=

# Plausible Analytics — privacy-friendly pageview tracking
# Get the script id from your Plausible dashboard (looks like "pa-TsvQfIzzKqn4Ko-W_Z6bE")
# New format (preferred): set NEXT_PUBLIC_PLAUSIBLE_SCRIPT_ID
# Legacy format (fallback): set NEXT_PUBLIC_PLAUSIBLE_DOMAIN + optional NEXT_PUBLIC_PLAUSIBLE_HOST
NEXT_PUBLIC_PLAUSIBLE_SCRIPT_ID=

# Clerk — authentication
# Dashboard: https://dashboard.clerk.com
# Publishable key is public (used in browser); secret key MUST be marked
# Sensitive in Vercel. Webhook signing secret verifies user.created /
# user.updated / user.deleted events sent to /api/webhooks/clerk so we
# can sync into Supabase user_profiles.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SIGNING_SECRET=

# Telegram Bot (Source Health Monitor)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Admin
ADMIN_KEY=
CRON_SECRET=

# Email (Resend — resend.com)
RESEND_API_KEY=

# Social Media Auto-Post (optional)
TWITTER_BEARER_TOKEN=
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=

# Google Search Console (optional — unified daily report)
# Create a GCP Service Account with Search Console Readonly access
# See: https://developers.google.com/webmaster-tools/v1/prereqs
GSC_SERVICE_ACCOUNT_EMAIL=
GSC_PRIVATE_KEY=
GSC_SITE_URL=sc-domain:troiamedia.com

# Analytics (Plausible — optional)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_PLAUSIBLE_HOST=

# Error Tracking (optional)
NEXT_PUBLIC_SENTRY_DSN=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://troiamedia.com
