#!/bin/sh

echo "Pre-push checks..."

# 1. TypeScript check
echo "Running typecheck..."
npx tsc --noEmit || { echo "TypeScript errors found. Fix them before pushing."; exit 1; }

# 2. Lint (threshold mode — lower this number as you fix warnings)
echo "Running lint..."
npx eslint . --max-warnings 120 || { echo "Lint errors or too many warnings. Fix before pushing."; exit 1; }

# 3. Unit tests
echo "Running tests..."
npx vitest run || { echo "Tests failed. Fix them before pushing."; exit 1; }

echo "All pre-push checks passed!"
