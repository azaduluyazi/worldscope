#!/bin/sh

echo "Pre-push checks..."

# 1. TypeScript check
echo "Running typecheck..."
npx tsc --noEmit || { echo "TypeScript errors found. Fix them before pushing."; exit 1; }

# 2. Lint (baseline mode — current codebase has 19 legacy errors + 110 warnings)
# TODO: Fix legacy lint errors, then reduce threshold to 0
echo "Running lint..."
npx eslint . 2>&1 | tail -3
echo "(Lint check informational — legacy issues tracked separately)"

# 3. Unit tests
echo "Running tests..."
npx vitest run || { echo "Tests failed. Fix them before pushing."; exit 1; }

echo "All pre-push checks passed!"
